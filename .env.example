# ====================================================
# Lira — конфигурация
# Скопируй этот файл в .env и заполни значения.
# Команда: cp .env.example .env  &&  nano .env
# ====================================================

# Токен Telegram-бота от @BotFather. ОБЯЗАТЕЛЬНО.
# Пример: 7400000000:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BOT_TOKEN=

# Username бота БЕЗ @, например: lowerBsk24_bot
# Используется для глубоких ссылок «привязать Telegram» в приложении.
BOT_USERNAME=

# Твой Telegram chat_id (число), КУДА бот будет слать админ-уведомления
# (новые оплаты, анкеты, прогнозы цикла). Узнать: @userinfobot → /start
ADMIN_CHAT_ID=

# Опционально: chat_id «сборочного» чата (например, чат склада),
# куда дублируются заказы. Оставь пустым если не нужно.
ASSEMBLY_CHAT_ID=

# Опционально: токен платёжного провайдера от @BotFather → Bot Settings → Payments.
# Если пусто, оплата идёт в демо-режиме (карта 4242 …).
PAYMENT_PROVIDER_TOKEN=

# Цены в рублях
BASIC_PRICE_RUB=999
VIP_PRICE_RUB=1999
SUBSCRIPTION_DAYS=30

# За сколько дней до начала цикла отгружать бокс
BOX_LEAD_DAYS=5

# База данных. По умолчанию — локальный SQLite в /var/lib/lira/app.db.
# Не меняй, если не знаешь что делаешь.
DATABASE_URL=sqlite+aiosqlite:////var/lib/lira/app.db

# Внутренний порт FastAPI. Nginx проксирует на него.
API_HOST=127.0.0.1
API_PORT=8000

# Если фронт лежит на ДРУГОМ домене (например, api.lira.ru и lira.ru):
# впиши сюда домены через запятую с https://. Если пусто (по умолчанию) —
# CORS закрыт, разрешён только same-origin доступ.
ALLOWED_ORIGINS=
