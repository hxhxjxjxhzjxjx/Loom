# Telegram bot token (@BotFather → /newbot)
BOT_TOKEN=123456789:AA-replace-me

# Telegram chat ID for admin notifications (orders, pause requests).
# Forward any message to https://t.me/userinfobot to find yours.
ADMIN_CHAT_ID=

# Optional separate chat for box-assembly orders (defaults to ADMIN_CHAT_ID).
ASSEMBLY_CHAT_ID=

# Telegram Payments provider token (@BotFather → /mybots → Payments).
# Leave blank to enable manual ("Я оплатила") fallback for testing.
PAYMENT_PROVIDER_TOKEN=

# Database URL: SQLite for local dev; Postgres in docker-compose.
DATABASE_URL=sqlite+aiosqlite:///./flowcare.db

# FastAPI host/port
API_HOST=0.0.0.0
API_PORT=8000

# Box ships this many days before the predicted period.
BOX_LEAD_DAYS=5
