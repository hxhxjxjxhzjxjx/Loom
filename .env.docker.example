# ====================================================
# Lira — конфигурация для docker-compose
# Скопируй в .env и заполни нужные значения:  cp .env.docker.example .env
# ====================================================

# CORS. Если фронт и API на одном домене (как в этом образе) — оставь пустым.
# Если фронт где-то отдельно — впиши его origin(ы) через запятую:
# ALLOWED_ORIGINS=https://app.example.ru,https://www.example.ru
ALLOWED_ORIGINS=

# ---------- Telegram-бот (опционально) ----------
# Если не нужен бот, оставь BOT_TOKEN пустым и НЕ запускай профиль "bot"
# (см. README.docker.md). API будет работать сам по себе.

# Токен от @BotFather
BOT_TOKEN=

# Username бота БЕЗ @ (используется в deep-link'ах для привязки)
BOT_USERNAME=

# Твой Telegram chat_id — куда бот шлёт админ-уведомления.
# Узнать: @userinfobot → /start
ADMIN_CHAT_ID=

# Опционально: chat_id «сборочного» чата
ASSEMBLY_CHAT_ID=

# Опционально: токен платежей от @BotFather → Bot Settings → Payments.
# Если пусто — оплата в демо-режиме (тестовая карта 4242 ...).
PAYMENT_PROVIDER_TOKEN=

# Цены и срок подписки
BASIC_PRICE_RUB=999
VIP_PRICE_RUB=1999
SUBSCRIPTION_DAYS=30

# За сколько дней до начала цикла отгружать бокс
BOX_LEAD_DAYS=5

# Где запускать Telegram-polling.
# 1 = в процессе API (одноконтейнерные деплои, например Fly.io).
# 0 = в отдельном контейнере bot (docker compose --profile bot).
# setup.sh ставит RUN_BOT_IN_API=0 автоматически, когда BOT_TOKEN
# заполнен. Telegram допускает только ОДИН getUpdates на токен —
# двойной polling = потеря сообщений.
RUN_BOT_IN_API=1
